#!/usr/bin/env bash
# SIVA-Type F10 toggle. First press: open overlay + listen. Second press:
# stop + rewrite + type into the focused input. While busy: cancel.
# Starts the daemon on demand.

SOCK=/tmp/siva-type.sock

if ! socat -u OPEN:/dev/null UNIX-CONNECT:"$SOCK" 2>/dev/null; then
    rm -f "$SOCK"
    setsid -f siva-type-daemon >/dev/null 2>&1
    for _ in $(seq 1 50); do
        [[ -S "$SOCK" ]] && break
        sleep 0.1
    done
fi

echo '{"type":"toggle"}' | socat -t 1 - UNIX-CONNECT:"$SOCK"
